{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["es2020"],
    "declaration": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noImplicitReturns": true,
    "esModuleInterop": true,
    "inlineSourceMap": true,
    "inlineSources": true,
    "outDir": "dist",
    "skipLibCheck": true
  },
  "exclude": ["node_modules", "cdk.out"],
  "include": ["lib/**/*.ts"]
}
